@model OficinaWeb.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:linear-gradient(135deg,#1a1a2e,#0f3460);">
    <div class="card p-4" style="width:100%;max-width:400px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold">🔧 Car Repair System <span style="font-size:13px;background:#e63946;color:#fff;padding:2px 7px;border-radius:4px;vertical-align:middle;">BETA</span></h2>
            <p class="text-muted mb-0">Sistema de Gestão</p>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label">Usuário</label>
                <input asp-for="Username" class="form-control" placeholder="Digite seu usuário" autofocus />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Senha" class="form-label">Senha</label>
                <input asp-for="Senha" class="form-control" placeholder="Digite sua senha" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Entrar</button>
        </form>

    </div>
</div>
