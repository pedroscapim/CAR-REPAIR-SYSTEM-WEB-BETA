@model List<OficinaWeb.Models.ClienteViewModel>
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">👤 Clientes</h4>
    <a asp-action="Criar" class="btn btn-primary">+ Novo Cliente</a>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>Endereço</th>
                    <th>Bairro</th>
                    <th style="width:110px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Nome</td>
                        <td>@c.Telefone</td>
                        <td>@c.Endereco@(string.IsNullOrEmpty(c.NumeroCasa) ? "" : ", " + c.NumeroCasa)</td>
                        <td>@c.Bairro</td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Editar">✏️</a>
                            <button class="btn btn-sm btn-outline-danger" title="Excluir"
                                    onclick="confirmarExclusao(@c.Id, '@c.Nome.Replace("'","\\'")')">🗑️</button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Nenhum cliente cadastrado.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal confirmação exclusão -->
<div class="modal fade" id="modalExcluir" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Confirmar exclusão</h6>
            </div>
            <div class="modal-body">
                Excluir cliente <strong id="nomeExcluir"></strong>?
            </div>
            <div class="modal-footer p-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <form id="formExcluir" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm">Excluir</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmarExclusao(id, nome) {
        document.getElementById('nomeExcluir').textContent = nome;
        document.getElementById('formExcluir').action = '/Cliente/Excluir/' + id;
        new bootstrap.Modal(document.getElementById('modalExcluir')).show();
    }
</script>
}
